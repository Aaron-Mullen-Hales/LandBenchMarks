FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      solidProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

//solidModel     linearGeometryTotalDisplacement;
solidModel     nonLinearGeometryTotalLagrangianTotalDisplacement;

"linearGeometryTotalDisplacementCoeffs|nonLinearGeometryTotalLagrangianTotalDisplacementCoeffs"
{
    // Solution algorithm
    //solutionAlgorithm implicitSegregated;
    solutionAlgorithm PETScSNES;
    //solutionAlgorithm explicit;

    // PETSc options file used by PETScSNES
    optionsFile petscOptions.split;

    // Predictor D at the start of a new time step using U and A
    predictor yes;

    stabilisation
    {
        type        RhieChow;
        //type        alpha;
        scaleFactor 0.5;
    }
    //solvePressure yes;
    //pressureSmoothingCoeff 1.0;                                                                                                                           
    //    omega    omega [0 0 0 0 0 0 0] .0625e3;
    //omegaTau    omegaTau [-1 1 3 0 0 0 0] 0.0;

    //Scaling and pressure units optioins
    //stabilidationType rhieChow;
    //unitsPressureScale 1.0e1;
    //matrixScale  1.0; //1.0e8;
    solvePressure true;
    pressureSmoothingCoeff 1.0;
    stabilisationType oosterlee;
    omega    omega [0 0 0 0 0 0 0] 0.125;
    omegaTau    omegaTau [0 0 0 0 0 0 0] 0.0;
    mu          mu [1 -1 -2 0 0 0 0] 2.62507e+07;
    lambda      lambda [1 -1 -2 0 0 0 0] 5.24856e+07;
    pressureConfig none;
    
}

