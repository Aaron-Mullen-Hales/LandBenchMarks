        patches
        (
            wall_outer-geom-1-solid1
            wall_outer-geom-1-solid2
            wall_outer-geom-1-solid3
        );
    }

    {
        name fixed;
        patchInfo
        {
            type wall;
        }
        constructFrom patches;
        patches
        (
            top-geom-1-solid2
            top-geom-1-solid3
        );
    }

    {
        name symmetry_1;
        patchInfo
        {
            type symmetryPlane;
        }
        constructFrom patches;
        patches
        (
            symmetry_1-geom-1-solid1
            symmetry_1-geom-1-solid2
        );
    }

    {
        name symmetry_2;
        patchInfo
        {
            type symmetryPlane;
        }
